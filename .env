# --- [ 核心身分驗證 ] ---
# 從 Google AI Studio 取得的 API Key
GEMINI_API_KEY=YourAPIKey

# 從 Telegram BotFather 取得的 Token
TELEGRAM_BOT_TOKEN=YourToken

# 允許操作機器人的 Telegram User ID (多組請用逗號分隔，例如 12345,67890)
ALLOWED_TELEGRAM_USER_IDS=55035231xx

# --- [ 戰術效能優化 ] ---
# 節能模式：設定背景檢查間隔。
# 建議設為 24h 或 168h，能極大程度防止 Google API 出現 Rate Limit 封鎖。
OPENCLAW__AGENTS__DEFAULTS__HEARTBEAT__CADENCE=168h

# 執行環境設定
NODE_ENV=production

# 網路穩壓器：強制 Node.js 優先使用 IPv4，解決 AWS/雲端環境 IPv6 連線超時問題。
NODE_OPTIONS="--dns-result-order=ipv4first"

# --- [ 雜訊過濾 (選配) ] ---
# 禁用 Bonjour 服務發現，減少雲端環境下的日誌報錯雜訊。
OPENCLAW__GATEWAY__DISCOVERY__ENABLED=false
